      {
        "accepted_answer": false,
        "actions_summary": [],
        "admin": false,
        "avatar_template": "/user_avatar/forum.bambulab.com/professional3d/{size}/106684_2.png",
        "badges_granted": [],
        "bookmarked": false,
        "can_accept_answer": false,
        "can_delete": false,
